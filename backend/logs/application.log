MESSAGE: DATABASE SELECT: student

DATABASE OPERATION:
  Operation: SELECT
  Table: student
  Duration: 463msms

SQL QUERY:
SELECT "public"."Student"."id",
        "public"."Student"."skillLevel"::text,
        "public"."Student"."totalLearningTime",
        "public"."Student"."userId",
        COALESCE("aggr_selection_0_Enrollment"."_aggr_count_enrollments",
        0) AS "_aggr_count_enrollments",
        COALESCE("aggr_selection_1_Review"."_aggr_count_reviews",
        0) AS "_aggr_count_reviews" 
      FROM "public"."Student" 
      LEFT JOIN (
      SELECT "public"."Enrollment"."studentId",
        COUNT(*) AS "_aggr_count_enrollments" 
      FROM "public"."Enrollment" 
      WHERE 1=1 
      GROUP BY "public"."Enrollment"."studentId") AS "aggr_selection_0_Enrollment" 
        ON ("public"."Student"."id" = "aggr_selection_0_Enrollment"."studentId") 
      LEFT JOIN (
      SELECT "public"."Review"."studentId",
        COUNT(*) AS "_aggr_count_reviews" 
      FROM "public"."Review" 
      WHERE 1=1 
      GROUP BY "public"."Review"."studentId") AS "aggr_selection_1_Review" 
        ON ("public"."Student"."id" = "aggr_selection_1_Review"."studentId") 
      WHERE "public"."Student"."userId" IN ($1,
        $2,
        $3) 
      OFFSET $4

