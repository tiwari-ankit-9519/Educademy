        ON ("public"."Course"."id" = "aggr_selection_0_Enrollment"."courseId") 
      LEFT JOIN (
      SELECT "public"."Review"."courseId",
        COUNT(*) AS "_aggr_count_reviews" 
      FROM "public"."Review" 
      WHERE 1=1 
      GROUP BY "public"."Review"."courseId") AS "aggr_selection_1_Review" 
        ON ("public"."Course"."id" = "aggr_selection_1_Review"."courseId") 
      LEFT JOIN (
      SELECT "public"."Section"."courseId",
        COUNT(*) AS "_aggr_count_sections" 
      FROM "public"."Section" 
      WHERE 1=1 
      GROUP BY "public"."Section"."courseId") AS "aggr_selection_2_Section" 
