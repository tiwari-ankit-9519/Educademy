MESSAGE: DATABASE SELECT: course

DATABASE OPERATION:
  Operation: SELECT
  Table: course
  Duration: 216msms

SQL QUERY:
SELECT c.id as course_id,
        s.id as section_id,
        s.title as section_title,
        s."order" as section_order,
        l.id as lesson_id,
        l.title as lesson_title,
        l."order" as lesson_order,
        COUNT(DISTINCT lc."studentId") as students_accessed,
        AVG(lc."timeSpent") as avg_time_spent,
        AVG(lc."completionPercentage") as avg_completion,
        COUNT(CASE WHEN lc."completionPercentage" >= 100 THEN 1 END) as completed_count,
        COUNT(CASE WHEN lc."completionPercentage" >= 80 THEN 1 END) as mostly_completed,
        AVG(lc."engagementScore") as avg_engagement_score,
        COUNT(lc.id) as total_views 
      FROM "Course" c JOIN "Section" s 
        ON c.id = s."courseId" JOIN "Lesson" l 
        ON s.id = l."sectionId" 
      LEFT JOIN "LessonCompletion" lc 
        ON l.id = lc."lessonId" 
      WHERE c.id = ANY($1::text[]) 
        AND (lc."createdAt" IS NULL 
        OR (lc."createdAt" >= $2 
        AND lc."createdAt" <= $3)) 
      GROUP BY c.id,
        s.id,
        s.title,
        s."order",
        l.id,
        l.title,
        l."order" 
      ORDER BY c.id,
        s."order",
        l."order"

