TIMESTAMP: 2025-06-04 12:34:15.454
LEVEL: INFO
PID: 15668
REQUEST_ID: N/A
CLASS.METHOD: Unknown.unknown
MESSAGE: DATABASE SELECT: user

DATABASE OPERATION:
  Operation: SELECT
  Table: user
  Duration: 496msms

SQL QUERY:
SELECT "public"."User"."id",
        "public"."User"."createdAt",
        "public"."User"."updatedAt",
        "public"."User"."email",
        "public"."User"."passwordHash",
        "public"."User"."salt",
        "public"."User"."firstName",
        "public"."User"."lastName",
        "public"."User"."profileImage",
        "public"."User"."bio",
        "public"."User"."role"::text,
        "public"."User"."isVerified",
        "public"."User"."isActive",
        "public"."User"."lastLogin",
        "public"."User"."timezone",
        "public"."User"."language",
        "public"."User"."country",
        "public"."User"."phoneNumber",
        "public"."User"."dateOfBirth",
        "public"."User"."website",
        "public"."User"."linkedinProfile",
        "public"."User"."twitterProfile",
        "public"."User"."githubProfile",
        COALESCE("aggr_selection_0_Session"."_aggr_count_sessions",
        0) AS "_aggr_count_sessions",
        COALESCE("aggr_selection_1_Activity"."_aggr_count_activities",
        0) AS "_aggr_count_activities" 
      FROM "public"."User" 
      LEFT JOIN (
      SELECT "public"."Session"."userId",
        COUNT(*) AS "_aggr_count_sessions" 
      FROM "public"."Session" 
      WHERE 1=1 
      GROUP BY "public"."Session"."userId") AS "aggr_selection_0_Session" 
        ON ("public"."User"."id" = "aggr_selection_0_Session"."userId") 
      LEFT JOIN (
      SELECT "public"."Activity"."userId",
        COUNT(*) AS "_aggr_count_activities" 
      FROM "public"."Activity" 
      WHERE 1=1 
