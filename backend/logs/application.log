TIMESTAMP: 2025-06-10 22:07:15.415
LEVEL: INFO
PID: 15552
REQUEST_ID: N/A
CLASS.METHOD: Unknown.unknown
MESSAGE: DATABASE SELECT: course

DATABASE OPERATION:
  Operation: SELECT
  Table: course
  Duration: 460msms

SQL QUERY:
SELECT c.id as course_id,
        c.title,
        COUNT(DISTINCT s.id) as total_sections,
        COUNT(DISTINCT l.id) as total_lessons,
        COUNT(DISTINCT q.id) as total_quizzes,
        COUNT(DISTINCT a.id) as total_assignments,
        AVG(lc."timeSpent") as avg_lesson_completion,
        AVG(qa."score") as avg_quiz_score,
        AVG(asub.grade) as avg_assignment_grade 
      FROM "Course" c 
      LEFT JOIN "Section" s 
        ON c.id = s."courseId" 
      LEFT JOIN "Lesson" l 
        ON s.id = l."sectionId" 
      LEFT JOIN "Quiz" q 
        ON s.id = q."sectionId" 
      LEFT JOIN "Assignment" a 
        ON s.id = a."sectionId" 
      LEFT JOIN "LessonCompletion" lc 
        ON l.id = lc."lessonId" 
      LEFT JOIN "QuizAttempt" qa 
        ON q.id = qa."quizId" 
      LEFT JOIN "AssignmentSubmission" asub 
        ON a.id = asub."assignmentId" 
      WHERE c.id = ANY($1::text[]) 
      GROUP BY c.id,
        c.title

SYSTEM CONTEXT:
  Environment: development
  Hostname: Kratos
  Platform: win32
  Node Version: v20.16.0
