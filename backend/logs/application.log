SELECT c.id as course_id,
        c.title as course_title,
        COUNT(p.id) as transaction_count,
        SUM(p.amount) as gross_revenue,
        SUM(ear.amount) as net_revenue,
        SUM(ear."platformFee") as platform_fees,
        AVG(p.amount) as avg_transaction_value,
        COUNT(DISTINCT e."studentId") as paying_students 
      FROM "Course" c 
      LEFT JOIN "Enrollment" e 
        ON c.id = e."courseId" 
      LEFT JOIN "Payment" p 
        ON e.id = p."enrollmentId" 
        AND p."createdAt" >= $1 
        AND p."createdAt" <= $2 
        AND p.status = 'COMPLETED' 
      LEFT JOIN "Earning" ear 
        ON p.id = ear."paymentId" 
      WHERE c."instructorId" = $3 
        AND p.id IS NOT NULL 
      GROUP BY c.id,
        c.title 
      ORDER BY gross_revenue DESC 
