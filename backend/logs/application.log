        COUNT(CASE WHEN e."lastAccessedAt" >= (e."createdAt" + INTERVAL '90 days') THEN 1 END) as retained_90_days,
        AVG(e.progress) as avg_progress_at_30_days 
      FROM "Enrollment" e JOIN "Course" c 
        ON e."courseId" = c.id 
      WHERE c."instructorId" = $1 
        AND e."createdAt" >= $2 
        AND e."createdAt" <= $3 
      GROUP BY DATE_TRUNC('month',
