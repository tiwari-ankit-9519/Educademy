TIMESTAMP: 2025-06-10 22:07:13.808
LEVEL: INFO
PID: 15552
REQUEST_ID: N/A
CLASS.METHOD: Unknown.unknown
MESSAGE: DATABASE SELECT: payment

DATABASE OPERATION:
  Operation: SELECT
  Table: payment
  Duration: 440msms

SQL QUERY:
SELECT DATE_TRUNC('day',
        p."createdAt") as period,
        c.id as course_id,
        c.title,
        SUM(p.amount) as gross_revenue,
        SUM(e.amount) as net_revenue,
        SUM(e."platformFee") as platform_fees,
        COUNT(p.id) as transactions,
        AVG(p.amount) as avg_transaction_value 
      FROM "Payment" p JOIN "Enrollment" en 
        ON p.id = en."paymentId" JOIN "Course" c 
        ON en."courseId" = c.id JOIN "Earning" e 
        ON p.id = e."paymentId" 
      WHERE c.id = ANY($1::text[]) 
        AND p."createdAt" >= $2 
        AND p."createdAt" <= $3 
        AND p.status = 'COMPLETED' 
      GROUP BY DATE_TRUNC('day',
        p."createdAt"),
        c.id,
        c.title 
      ORDER BY period,
        c.id

SYSTEM CONTEXT:
  Environment: development
  Hostname: Kratos
  Platform: win32
  Node Version: v20.16.0
