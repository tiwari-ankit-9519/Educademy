LEVEL: INFO
PID: 15552
REQUEST_ID: N/A
CLASS.METHOD: Unknown.unknown
MESSAGE: DATABASE SELECT: course

DATABASE OPERATION:
  Operation: SELECT
  Table: course
  Duration: 446msms

SQL QUERY:
SELECT c.id as course_id,
        c.title,
        COUNT(DISTINCT sal."studentId") as active_students,
        COUNT(CASE WHEN sal."activityType" = 'lesson_view' THEN 1 END) as lesson_views,
        COUNT(CASE WHEN sal."activityType" = 'lesson_complete' THEN 1 END) as lesson_completions,
        COUNT(CASE WHEN sal."activityType" = 'quiz_attempt' THEN 1 END) as quiz_attempts,
        COUNT(CASE WHEN sal."activityType" = 'assignment_submit' THEN 1 END) as assignment_submissions,
        COUNT(CASE WHEN sal."activityType" = 'discussion_post' THEN 1 END) as discussion_posts,
        AVG(sal."timeSpent") as avg_session_time,
        AVG(sal."progress") as avg_engagement_score 
      FROM "Course" c 
      LEFT JOIN "StudentActivityLog" sal 
        ON c.id = sal."courseId" 
      WHERE c.id = ANY($1::text[]) 
        AND (sal."createdAt" IS NULL 
        OR (sal."createdAt" >= $2 
        AND sal."createdAt" <= $3)) 
      GROUP BY c.id,
        c.title

