MESSAGE: DATABASE SELECT: course

DATABASE OPERATION:
  Operation: SELECT
  Table: course
  Duration: 218msms

SQL QUERY:
SELECT c.id as course_id,
        CASE WHEN sal_avg."avg_engagement" >= 8 THEN 'high' WHEN sal_avg."avg_engagement" >= 6 THEN 'medium' ELSE 'low' END as engagement_level,
        COUNT(DISTINCT e."studentId") as student_count,
        AVG(e.progress) as avg_progress,
        COUNT(CASE WHEN e.status = 'COMPLETED' THEN 1 END) as completed_count,
        AVG(e."totalTimeSpent") as avg_total_time,
        AVG(e."sessionsCount") as avg_sessions 
      FROM "Course" c 
      LEFT JOIN "Enrollment" e 
        ON c.id = e."courseId" 
      LEFT JOIN ( 
      SELECT "studentId",
        "courseId",
        AVG("engagementScore") as avg_engagement 
      FROM "StudentActivityLog" 
      WHERE "createdAt" >= $1 
        AND "createdAt" <= $2 
      GROUP BY "studentId",
        "courseId" ) sal_avg 
        ON e."studentId" = sal_avg."studentId" 
        AND c.id = sal_avg."courseId" 
      WHERE c.id = ANY($3::text[]) 
      GROUP BY c.id,
        engagement_level 
      ORDER BY c.id,
        engagement_level

