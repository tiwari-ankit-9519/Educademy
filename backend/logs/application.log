        COUNT(sal.id) as session_count,
        AVG(sal."timeSpent") as avg_session_duration,
        AVG(sal."engagementScore") as avg_engagement,
        COUNT(DISTINCT sal."studentId") as unique_users 
      FROM "Course" c JOIN "StudentActivityLog" sal 
        ON c.id = sal."courseId" 
      WHERE c.id = ANY($1::text[]) 
        AND sal."createdAt" >= $2 
        AND sal."createdAt" <= $3 
      GROUP BY c.id,
        sal."deviceType",
        sal."location",
        sal."browserType" 
      ORDER BY c.id,
        session_count DESC

