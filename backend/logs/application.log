TIMESTAMP: 2025-06-03 12:26:20.894
LEVEL: INFO
PID: 24056
REQUEST_ID: N/A
CLASS.METHOD: Unknown.unknown
MESSAGE: DATABASE SELECT: category

DATABASE OPERATION:
  Operation: SELECT
  Table: category
  Duration: 475msms

SQL QUERY:
SELECT "public"."Category"."id",
        "public"."Category"."name",
        COALESCE("aggr_selection_0_Course"."_aggr_count_courses",
        0) AS "_aggr_count_courses" 
      FROM "public"."Category" 
      LEFT JOIN (
      SELECT "public"."Course"."categoryId",
        COUNT(*) AS "orderby_aggregator" 
      FROM "public"."Course" 
      WHERE 1=1 
      GROUP BY "public"."Course"."categoryId") AS "orderby_1_Course" 
        ON ("public"."Category"."id" = "orderby_1_Course"."categoryId") 
      LEFT JOIN (
      SELECT "public"."Course"."categoryId",
        COUNT(*) AS "_aggr_count_courses" 
      FROM "public"."Course" 
      WHERE 1=1 
      GROUP BY "public"."Course"."categoryId") AS "aggr_selection_0_Course" 
        ON ("public"."Category"."id" = "aggr_selection_0_Course"."categoryId") 
      WHERE 1=1 
      ORDER BY COALESCE("orderby_1_Course"."orderby_aggregator",
        $1) DESC 
      LIMIT $2 
      OFFSET $3

SYSTEM CONTEXT:
  Environment: development
  Hostname: Kratos
  Platform: win32
  Node Version: v20.16.0
