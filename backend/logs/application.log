TIMESTAMP: 2025-06-10 22:07:15.416
LEVEL: INFO
PID: 15552
REQUEST_ID: N/A
CLASS.METHOD: Unknown.unknown
MESSAGE: DATABASE SELECT: course

DATABASE OPERATION:
  Operation: SELECT
  Table: course
  Duration: 457msms

SQL QUERY:
SELECT c.id as course_id,
        c.title,
        COUNT(r.id) as total_reviews,
        AVG(r.rating) as avg_rating,
        COUNT(CASE WHEN r.rating >= 5 THEN 1 END) as five_star,
        COUNT(CASE WHEN r.rating >= 4 THEN 1 END) as four_plus_star,
        COUNT(CASE WHEN r.rating <= 2 THEN 1 END) as poor_reviews,
        COUNT(CASE WHEN LENGTH(r.content) > 100 THEN 1 END) as detailed_reviews,
        AVG(LENGTH(r.content)) as avg_review_length 
      FROM "Course" c 
      LEFT JOIN "Review" r 
        ON c.id = r."courseId" 
      WHERE c.id = ANY($1::text[]) 
        AND (r."createdAt" IS NULL 
        OR (r."createdAt" >= $2 
        AND r."createdAt" <= $3)) 
      GROUP BY c.id,
        c.title

