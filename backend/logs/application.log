TIMESTAMP: 2025-06-10 22:07:15.300
LEVEL: INFO
PID: 15552
REQUEST_ID: N/A
CLASS.METHOD: Unknown.unknown
MESSAGE: DATABASE SELECT: enrollment

DATABASE OPERATION:
  Operation: SELECT
  Table: enrollment
  Duration: 435msms

SQL QUERY:
SELECT DATE_TRUNC('day',
        e."createdAt") as period,
        c.id as course_id,
        c.title,
        COUNT(e.id) as enrollments,
        COUNT(CASE WHEN e.status = 'ACTIVE' THEN 1 END) as active_enrollments,
        COUNT(CASE WHEN e.status = 'COMPLETED' THEN 1 END) as completed_enrollments,
        AVG(e.progress) as avg_progress 
      FROM "Enrollment" e JOIN "Course" c 
        ON e."courseId" = c.id 
      WHERE c.id = ANY($1::text[]) 
        AND e."createdAt" >= $2 
        AND e."createdAt" <= $3 
      GROUP BY DATE_TRUNC('day',
        e."createdAt"),
        c.id,
        c.title 
      ORDER BY period,
        c.id

