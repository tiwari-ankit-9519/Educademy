CLASS.METHOD: Unknown.unknown
MESSAGE: DATABASE SELECT: course

DATABASE OPERATION:
  Operation: SELECT
  Table: course
  Duration: 454msms

SQL QUERY:
SELECT c.id as course_id,
        c.title,
        COUNT(e.id) as total_enrollments,
        COUNT(CASE WHEN e.progress >= 100 THEN 1 END) as completed,
        COUNT(CASE WHEN e.progress >= 75 THEN 1 END) as nearly_completed,
        COUNT(CASE WHEN e.progress >= 50 THEN 1 END) as halfway,
        COUNT(CASE WHEN e.progress >= 25 THEN 1 END) as quarter_completed,
        COUNT(CASE WHEN e.progress < 10 THEN 1 END) as early_dropoff,
        AVG(e.progress) as avg_completion_rate,
        AVG(e."totalTimeSpent") as avg_time_spent,
        AVG(CASE WHEN e.progress >= 100 THEN e."totalTimeSpent" END) as avg_completion_time 
      FROM "Course" c 
      LEFT JOIN "Enrollment" e 
        ON c.id = e."courseId" 
      WHERE c.id = ANY($1::text[]) 
        AND (e."createdAt" IS NULL 
        OR (e."createdAt" >= $2 
        AND e."createdAt" <= $3)) 
      GROUP BY c.id,
        c.title

