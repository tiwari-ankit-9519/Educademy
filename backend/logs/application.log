  Duration: 451msms

SQL QUERY:
SELECT DATE_TRUNC('month',
        p."createdAt") as month,
        SUM(p.amount) as gross_revenue,
        SUM(ear.amount) as net_revenue,
        SUM(ear."platformFee") as platform_fees,
        COUNT(p.id) as transactions,
        AVG(p.amount) as avg_transaction_value,
        COUNT(DISTINCT c.id) as revenue_generating_courses 
      FROM "Payment" p JOIN "Enrollment" e 
