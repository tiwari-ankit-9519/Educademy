MESSAGE: DATABASE SELECT: course

DATABASE OPERATION:
  Operation: SELECT
  Table: course
  Duration: 217msms

SQL QUERY:
SELECT c.id as course_id,
        c.title as course_title,
        COUNT(DISTINCT s.id) as total_sections,
        COUNT(DISTINCT l.id) as total_lessons,
        COUNT(DISTINCT q.id) as total_quizzes,
        COUNT(DISTINCT a.id) as total_assignments,
        AVG(lc."completionPercentage") as avg_lesson_completion,
        COUNT(DISTINCT lc."studentId") as students_accessing_content 
      FROM "Course" c 
      LEFT JOIN "Section" s 
        ON c.id = s."courseId" 
      LEFT JOIN "Lesson" l 
        ON s.id = l."sectionId" 
      LEFT JOIN "Quiz" q 
        ON s.id = q."sectionId" 
      LEFT JOIN "Assignment" a 
        ON s.id = a."sectionId" 
      LEFT JOIN "LessonCompletion" lc 
        ON l.id = lc."lessonId" 
        AND lc."createdAt" >= $1 
        AND lc."createdAt" <= $2 
      WHERE c."instructorId" = $3 
      GROUP BY c.id,
        c.title 
      ORDER BY students_accessing_content DESC 
      LIMIT 10

