REQUEST_ID: N/A
CLASS.METHOD: Unknown.unknown
MESSAGE: DATABASE SELECT: enrollment

DATABASE OPERATION:
  Operation: SELECT
  Table: enrollment
  Duration: 509msms

SQL QUERY:
SELECT 'enrollment' as activity_type,
        e."createdAt" as activity_date,
        u."firstName" || ' ' || u."lastName" as student_name,
        c.title as course_title,
        c.id as course_id,
        e.id as reference_id 
      FROM "Enrollment" e JOIN "Course" c 
        ON e."courseId" = c.id JOIN "Student" s 
        ON e."studentId" = s.id JOIN "User" u 
        ON s."userId" = u.id 
      WHERE c."instructorId" = $1 
        AND e."createdAt" >= $2 UNION ALL 
      SELECT 'review' as activity_type,
        r."createdAt" as activity_date,
        u."firstName" || ' ' || u."lastName" as student_name,
        c.title as course_title,
        c.id as course_id,
        r.id as reference_id 
      FROM "Review" r JOIN "Course" c 
        ON r."courseId" = c.id JOIN "Student" s 
        ON r."studentId" = s.id JOIN "User" u 
        ON s."userId" = u.id 
      WHERE c."instructorId" = $3 
        AND r."createdAt" >= $4 UNION ALL 
      SELECT 'completion' as activity_type,
        e."updatedAt" as activity_date,
        u."firstName" || ' ' || u."lastName" as student_name,
        c.title as course_title,
        c.id as course_id,
        e.id as reference_id 
      FROM "Enrollment" e JOIN "Course" c 
        ON e."courseId" = c.id JOIN "Student" s 
        ON e."studentId" = s.id JOIN "User" u 
        ON s."userId" = u.id 
      WHERE c."instructorId" = $5 
        AND e.progress >= 100 
        AND e."updatedAt" >= $6 
      ORDER BY activity_date DESC 
      LIMIT 20

