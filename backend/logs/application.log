TIMESTAMP: 2025-06-10 22:07:15.435
LEVEL: INFO
PID: 15552
REQUEST_ID: N/A
CLASS.METHOD: Unknown.unknown
MESSAGE: DATABASE SELECT: course

DATABASE OPERATION:
  Operation: SELECT
  Table: course
  Duration: 455msms

SQL QUERY:
SELECT c.id as course_id,
        s."order" as section_order,
        s.title as section_title,
        COUNT(DISTINCT e.id) as enrolled_students,
        COUNT(DISTINCT cp."enrollmentId") as students_reached_section,
        (COUNT(DISTINCT cp."enrollmentId")::float / NULLIF(COUNT(DISTINCT e.id),
        0) * 100) as retention_rate 
      FROM "Course" c JOIN "Section" s 
        ON c.id = s."courseId" 
      LEFT JOIN "Enrollment" e 
        ON c.id = e."courseId" 
      LEFT JOIN "CourseProgress" cp 
        ON e.id = cp."enrollmentId" 
        AND cp."currentSectionId" = s.id 
      WHERE c.id = ANY($1::text[]) 
      GROUP BY c.id,
        s.id,
        s."order",
        s.title 
      ORDER BY c.id,
        s."order"

