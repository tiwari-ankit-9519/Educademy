        AND r."createdAt" >= $3 
        AND r."createdAt" <= $4 
      LEFT JOIN "Payment" p 
        ON e.id = p."enrollmentId" 
        AND p."createdAt" >= $5 
        AND p."createdAt" <= $6 
      WHERE c."instructorId" = $7 
      GROUP BY c.id,
        c.title,
        c.status,
        c.price,
        c."averageRating",
        c."totalEnrollments",
        c."totalRevenue" 
      ORDER BY period_enrollments DESC,
