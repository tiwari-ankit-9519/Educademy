  Duration: 238msms

SQL QUERY:
SELECT c.id as course_id,
        c.title as course_title,
        COUNT(DISTINCT sal."studentId") as active_students,
        AVG(sal."engagementScore") as avg_engagement_score,
        AVG(sal."timeSpent") as avg_session_duration,
        COUNT(sal.id) as total_sessions,
        COUNT(CASE WHEN sal."activityType" = 'lesson_complete' THEN 1 END) as lesson_completions,
        COUNT(CASE WHEN sal."activityType" = 'quiz_complete' THEN 1 END) as quiz_completions,
        COUNT(CASE WHEN sal."activityType" = 'discussion_post' THEN 1 END) as discussion_posts 
      FROM "Course" c 
      LEFT JOIN "StudentActivityLog" sal 
        ON c.id = sal."courseId" 
        AND sal."createdAt" >= $1 
        AND sal."createdAt" <= $2 
      WHERE c."instructorId" = $3 
      GROUP BY c.id,
        c.title 
      HAVING COUNT(sal.id) > 0 
      ORDER BY avg_engagement_score DESC 
      LIMIT 10

