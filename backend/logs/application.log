MESSAGE: DATABASE SELECT: course

DATABASE OPERATION:
  Operation: SELECT
  Table: course
  Duration: 426msms

SQL QUERY:
SELECT cat.name as category,
        COUNT(CASE WHEN c."instructorId" = $1 THEN 1 END) as instructor_courses,
        COUNT(c.id) as total_courses_in_category,
        AVG(CASE WHEN c."instructorId" = $2 THEN c."totalEnrollments" END) as instructor_avg_enrollments,
        AVG(c."totalEnrollments") as category_avg_enrollments,
        AVG(CASE WHEN c."instructorId" = $3 THEN c."averageRating" END) as instructor_avg_rating,
        AVG(c."averageRating") as category_avg_rating 
      FROM "Course" c JOIN "Category" cat 
        ON c."categoryId" = cat.id 
      WHERE cat.id IN ( 
      SELECT DISTINCT "categoryId" 
      FROM "Course" 
      WHERE "instructorId" = $4 ) 
        AND c.status = 'PUBLISHED' 
      GROUP BY cat.id,
        cat.name

