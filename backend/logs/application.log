SQL QUERY:
SELECT c.id as course_id,
        'enrollment_to_first_lesson' as funnel_step,
        COUNT(DISTINCT e."studentId") as total_students,
        COUNT(DISTINCT CASE WHEN lc."studentId" IS NOT NULL THEN e."studentId" END) as converted_students 
      FROM "Course" c 
      LEFT JOIN "Enrollment" e 
        ON c.id = e."courseId" 
      LEFT JOIN "LessonCompletion" lc 
        ON e."studentId" = lc."studentId" 
      LEFT JOIN "Lesson" l 
        ON lc."lessonId" = l.id 
      LEFT JOIN "Section" s 
        ON l."sectionId" = s.id 
        AND s."courseId" = c.id 
      WHERE c.id = ANY($1::text[]) 
        AND (e."createdAt" IS NULL 
        OR (e."createdAt" >= $2 
        AND e."createdAt" <= $3)) 
      GROUP BY c.id UNION ALL 
      SELECT c.id as course_id,
        'first_lesson_to_completion' as funnel_step,
        COUNT(DISTINCT CASE WHEN lc."studentId" IS NOT NULL THEN e."studentId" END) as total_students,
        COUNT(DISTINCT CASE WHEN e.progress >= 100 THEN e."studentId" END) as converted_students 
      FROM "Course" c 
      LEFT JOIN "Enrollment" e 
        ON c.id = e."courseId" 
      LEFT JOIN "LessonCompletion" lc 
        ON e."studentId" = lc."studentId" 
      WHERE c.id = ANY($4::text[]) 
        AND (e."createdAt" IS NULL 
        OR (e."createdAt" >= $5 
        AND e."createdAt" <= $6)) 
      GROUP BY c.id

