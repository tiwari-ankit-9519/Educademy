        ON e."courseId" = c.id JOIN "Earning" ear 
        ON p.id = ear."paymentId" 
      WHERE c."instructorId" = $1 
        AND p."createdAt" >= $2 
        AND p."createdAt" <= $3 
        AND p.status = 'COMPLETED' 
      GROUP BY DATE_TRUNC('month',
