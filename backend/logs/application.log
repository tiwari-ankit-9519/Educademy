MESSAGE: DATABASE SELECT: payment

DATABASE OPERATION:
  Operation: SELECT
  Table: payment
  Duration: 232msms

SQL QUERY:
SELECT DATE_TRUNC('month',
        p."createdAt") as month,
        SUM(p.amount) as gross_revenue,
        SUM(ear.amount) as net_revenue,
        SUM(ear."platformFee") as platform_fees,
        COUNT(p.id) as transactions,
        AVG(p.amount) as avg_transaction_value,
        COUNT(DISTINCT c.id) as revenue_generating_courses 
      FROM "Payment" p JOIN "Enrollment" e 
        ON p."enrollmentId" = e.id JOIN "Course" c 
        ON e."courseId" = c.id JOIN "Earning" ear 
        ON p.id = ear."paymentId" 
      WHERE c."instructorId" = $1 
        AND p."createdAt" >= $2 
        AND p."createdAt" <= $3 
        AND p.status = 'COMPLETED' 
      GROUP BY DATE_TRUNC('month',
        p."createdAt") 
      ORDER BY month

