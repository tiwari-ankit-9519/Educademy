TIMESTAMP: 2025-06-10 22:07:15.460
LEVEL: INFO
PID: 15552
REQUEST_ID: N/A
CLASS.METHOD: Unknown.unknown
MESSAGE: DATABASE SELECT: course

DATABASE OPERATION:
  Operation: SELECT
  Table: course
  Duration: 471msms

SQL QUERY:
SELECT c.id as course_id,
        c.title,
        COUNT(CASE WHEN e."lastAccessedAt" >= $1 THEN 1 END) as active_last_week,
        COUNT(CASE WHEN e."lastAccessedAt" >= $2 THEN 1 END) as active_last_month,
        COUNT(CASE WHEN e."lastAccessedAt" < $3 THEN 1 END) as inactive_month,
        AVG(EXTRACT(EPOCH 
      FROM (e."lastAccessedAt" - e."createdAt"))/86400) as avg_retention_days,
        COUNT(DISTINCT e.id) as avg_sessions_per_student,
        AVG(e."totalTimeSpent") as avg_total_time_spent 
      FROM "Course" c 
      LEFT JOIN "Enrollment" e 
        ON c.id = e."courseId" 
      WHERE c.id = ANY($4::text[]) 
        AND e.status = 'ACTIVE' 
      GROUP BY c.id,
        c.title

