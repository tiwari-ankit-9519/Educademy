MESSAGE: DATABASE SELECT: course

DATABASE OPERATION:
  Operation: SELECT
  Table: course
  Duration: 253msms

SQL QUERY:
SELECT COUNT(DISTINCT c.id) as total_courses,
        COUNT(DISTINCT CASE WHEN c.status = 'PUBLISHED' THEN c.id END) as published_courses,
        COUNT(DISTINCT CASE WHEN c.status = 'DRAFT' THEN c.id END) as draft_courses,
        COUNT(DISTINCT e.id) as total_enrollments,
        COUNT(DISTINCT CASE WHEN e.status = 'ACTIVE' THEN e.id END) as active_enrollments,
        COUNT(DISTINCT CASE WHEN e.status = 'COMPLETED' THEN e.id END) as completed_enrollments,
        COUNT(DISTINCT r.id) as total_reviews,
        AVG(r.rating) as avg_rating,
        SUM(p.amount) as total_revenue,
        SUM(ear.amount) as net_revenue,
        COUNT(DISTINCT p.id) as total_transactions,
        COUNT(DISTINCT e."studentId") as unique_students,
        AVG(e.progress) as avg_student_progress,
        SUM(e."totalTimeSpent") as total_learning_time 
      FROM "Course" c 
      LEFT JOIN "Enrollment" e 
        ON c.id = e."courseId" 
        AND e."createdAt" >= $1 
        AND e."createdAt" <= $2 
      LEFT JOIN "Review" r 
        ON c.id = r."courseId" 
        AND r."createdAt" >= $3 
        AND r."createdAt" <= $4 
      LEFT JOIN "Payment" p 
        ON e.id = p."enrollmentId" 
        AND p."createdAt" >= $5 
        AND p."createdAt" <= $6 
        AND p.status = 'COMPLETED' 
      LEFT JOIN "Earning" ear 
        ON p.id = ear."paymentId" 
      WHERE c."instructorId" = $7

